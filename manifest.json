{
  "manifest_version": 3,
  "name": "BombParty Helper",
  "version": "1.1",
  "description": "Extension pour trouver des mots dans BombParty",
  "permissions": ["storage"],
  "host_permissions": ["https://*.jklm.fun/*"],
  "content_scripts": [
    {
      "matches": ["https://*.jklm.fun/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dictionnaire.txt"],
      "matches": ["https://*.jklm.fun/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bombparty-helper@rangedace",
      "strict_min_version": "115.0"
    }
  }
}
